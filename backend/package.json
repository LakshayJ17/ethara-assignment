{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:all": "concurrently -n api,web -c \"#4d5b4a,#8c6d3f\" \"tsx watch src/server.ts\" \"npm run dev --prefix ../frontend\"",
    "build": "npm exec prisma generate && tsup src/server.ts --format esm --platform node --target node20 --out-dir dist --clean",
    "start": "npm exec prisma migrate deploy && node dist/server.js",
    "migrate:dev": "npm exec prisma migrate dev",
    "migrate:deploy": "npm exec prisma migrate deploy",
    "migrate:reset": "npm exec prisma migrate reset",
    "db:push": "npm exec prisma db push",
    "prisma:generate": "npm exec prisma generate",
    "postinstall": "npm exec prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.14",
    "concurrently": "^9.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
