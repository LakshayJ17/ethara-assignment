# Local dev: leave empty; Vite proxies /api to http://localhost:4000

# Optional: call the API directly (skips Vercel /api proxy). Must rebuild after changing.
# VITE_API_URL=https://your-app.up.railway.app

# Vercel only (runtime, no rebuild): Railway API origin, no trailing slash
# BACKEND_URL=https://your-app.up.railway.app
